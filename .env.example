# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
API_PREFIX=api

# ─── ROC SDK ──────────────────────────────────────────────────────────────────
# Directory containing *.rmodel files (usually the lib/ dir of the SDK volume)
ROC_MODEL_PATH=/Volumes/ROCSDK/lib

# Path to the ROC license file
ROC_LIC=/path/to/ROC-RC-MACOS.lic

# ─── Upload limits ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20

# ─── Authentication ───────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for the X-Api-Key header.
# Leave empty to disable authentication entirely (dev/internal use only).
API_KEYS=

# ─── Data Retention ───────────────────────────────────────────────────────────
# Number of days to keep detection events, face events, and alerts.
# Set to 0 to disable automatic purging.
RETENTION_DAYS=90

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Enable vehicle make/model/color classification and vehicle-first gating.
# Disable if roc_represent_object_ex causes instability on your hardware.
ENABLE_OBJECT_DETECTION=true

# Enable weapon/gun detection per frame (requires ENABLE_OBJECT_DETECTION=true).
ENABLE_GUN_DETECTION=true

# Persist face detection events to the face_events table.
PERSIST_FACE_EVENTS=true
